<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Leanback 主题（电视深色） -->
    <style name="Theme.TVBoxSimple" parent="Theme.Leanback">
        <item name="android:windowBackground">@color/tv_background</item>
        <item name="android:colorPrimary">@color/tv_primary</item>
        <item name="android:colorAccent">@color/tv_accent</item>
        <item name="android:statusBarColor">@color/tv_background</item>
        <item name="android:navigationBarColor">@color/tv_background</item>
    </style>

    <!-- 设置页用 Material 主题 -->
    <style name="Theme.TVBoxSimple.Settings" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/tv_background</item>
        <item name="colorPrimary">@color/tv_primary</item>
        <item name="colorOnPrimary">@color/tv_on_primary</item>
        <item name="colorAccent">@color/tv_accent</item>
    </style>
</resources>
