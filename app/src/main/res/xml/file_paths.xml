<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
      FileProvider paths 配置：用于 OTA 下载的 APK 走 FileProvider.getUriForFile 时
      把私有 cache 目录下的 apk 共享给系统安装器。
    -->
    <cache-path
        name="ota_cache"
        path="ota/" />
    <files-path
        name="files_root"
        path="." />
</paths>