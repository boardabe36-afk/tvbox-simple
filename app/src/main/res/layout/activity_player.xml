<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top bar: title + controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/player_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#80000000"
            android:maxWidth="900dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:padding="16dp"
            android:textColor="#FFFFFF"
            android:textSize="20sp" />

        <Button
            android:id="@+id/player_quality_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#80000000"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            android:text="@string/player_quality"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/player_audio_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#80000000"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            android:text="@string/player_audio_mode"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/player_speed_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#80000000"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            android:text="1.0x"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/player_autoplay_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#80000000"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            android:text="自动连播: 开"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/player_next_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#80000000"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            android:text="下一集"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginStart="8dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Bottom bar: episode list (shown when user toggles) -->
    <LinearLayout
        android:id="@+id/player_episodes_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="120dp"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/player_episodes_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/player_episodes"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/player_episodes_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="64dp"
            android:maxHeight="220dp"
            android:clipToPadding="false"
            android:scrollbars="none" />
    </LinearLayout>

    <!-- Quality / Audio mode dialog container -->
    <LinearLayout
        android:id="@+id/player_options_panel"
        android:layout_width="420dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="32dp"
        android:orientation="vertical"
        android:background="#EE0F1014"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/player_options_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/player_quality"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/player_options_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:maxHeight="420dp"
            android:clipToPadding="false"
            android:scrollbars="none" />
    </LinearLayout>

    <!-- Episode toggle button (bottom-right corner) -->
    <Button
        android:id="@+id/player_episodes_toggle_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="32dp"
        android:background="#80000000"
        android:paddingStart="24dp"
        android:paddingTop="14dp"
        android:paddingEnd="24dp"
        android:paddingBottom="14dp"
        android:text="@string/player_episodes"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

    <!-- Buffering spinner -->
    <ProgressBar
        android:id="@+id/player_loading"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:indeterminateTint="#FFFFFF"
        android:visibility="visible" />

    <!-- Error overlay -->
    <LinearLayout
        android:id="@+id/player_error_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="48dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/player_error_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠"
            android:textColor="#FF8A65"
            android:textSize="80sp" />

        <TextView
            android:id="@+id/player_error_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="播放失败"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/player_error_detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:maxWidth="900dp"
            android:textColor="#FFCCCC"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/player_retry_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/tv_primary"
                android:paddingStart="48dp"
                android:paddingTop="20dp"
                android:paddingEnd="48dp"
                android:paddingBottom="20dp"
                android:text="@string/retry"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

            <Button
                android:id="@+id/player_close_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:background="@color/tv_card_background"
                android:paddingStart="48dp"
                android:paddingTop="20dp"
                android:paddingEnd="48dp"
                android:paddingBottom="20dp"
                android:text="@string/back"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>